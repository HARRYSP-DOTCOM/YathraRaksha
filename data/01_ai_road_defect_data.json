{
  "metadata": {
    "file": "AI Road Defect Detection Dataset",
    "purpose": "Road defect detection using Gemini 3.5 Flash Vision API",
    "source": "Compiled from: IIT Bombay Road Dataset, Kaggle Road Damage Dataset (CRDDC2022), NHAI inspection reports",
    "license": "CC BY 4.0 for academic/non-commercial use",
    "last_updated": "2026"
  },
  "defect_classes": [
    {
      "class_id": 0,
      "class_name": "pothole",
      "description": "Bowl-shaped depression in road surface",
      "severity_levels": ["minor (<10cm dia)", "moderate (10-30cm)", "severe (>30cm)"],
      "typical_confidence_threshold": 0.70,
      "real_dataset_source": "Kaggle CRDDC2022 - 21,041 images from India, Japan, Czech Republic",
      "dataset_url": "https://crddc2022.sekilab.global/dataset/"
    },
    {
      "class_id": 1,
      "class_name": "alligator_cracking",
      "description": "Interconnected cracks forming polygon pattern (fatigue cracking)",
      "severity_levels": ["low (no pumping)", "medium (some loss)", "high (severe distortion)"],
      "typical_confidence_threshold": 0.65,
      "real_dataset_source": "RDD2022 - Road Damage Detection Dataset",
      "dataset_url": "https://github.com/sekilab/RoadDamageDetector"
    },
    {
      "class_id": 2,
      "class_name": "longitudinal_crack",
      "description": "Crack running parallel to road centerline",
      "severity_levels": ["fine (<3mm)", "medium (3-10mm)", "wide (>10mm)"],
      "typical_confidence_threshold": 0.65,
      "real_dataset_source": "RDD2022"
    },
    {
      "class_id": 3,
      "class_name": "transverse_crack",
      "description": "Crack perpendicular to road centerline",
      "severity_levels": ["fine", "medium", "wide"],
      "typical_confidence_threshold": 0.65,
      "real_dataset_source": "RDD2022"
    },
    {
      "class_id": 4,
      "class_name": "rutting",
      "description": "Depression/groove worn into road by repeated traffic",
      "severity_levels": ["shallow (<6mm)", "moderate (6-12mm)", "deep (>12mm)"],
      "typical_confidence_threshold": 0.72
    },
    {
      "class_id": 5,
      "class_name": "road_good_condition",
      "description": "Road surface with no visible defects",
      "typical_confidence_threshold": 0.80
    }
  ],
